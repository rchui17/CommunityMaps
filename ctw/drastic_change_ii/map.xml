<map proto="1.5.0">
  <name>Drastic Change II</name>
  <version>1.0.0</version>
  <objective>Capture the enemies' wools!</objective>
  <phase>development</phase>
  <include id="gapple-kill-reward"/>
  <authors>
    <author uuid="fe3608b7-d105-4029-8800-34b3147065b6"/> <!-- rockymine -->
  </authors>
  <teams>
    <team id="red" color="red" max="16">Red</team>
    <team id="blue" color="blue" max="16">Blue</team>
  </teams>
  <kits>
    <kit id="spawn-kit">
      <item slot="0" material="iron sword" unbreakable="true"/>
      <item slot="1" material="bow" unbreakable="true">
        <enchantment level="1">infinity</enchantment>
      </item>
      <item slot="2" material="iron pickaxe" unbreakable="true">
        <enchantment level="1">efficiency</enchantment>
      </item>
      <item slot="3" material="iron axe" unbreakable="true">
        <enchantment level="1">efficiency</enchantment>
      </item>
      <item slot="4" material="iron spade" unbreakable="true"/>
      <item slot="5" material="shears" unbreakable="true"/>
      <item slot="6" material="golden apple"/>
      <item slot="7" material="water bucket"/>
      <item slot="8" material="wood" amount="64"/>
      <item slot="9" material="arrow"/>
      <item slot="10" material="stained clay" amount="32" team-color="true"/>
      <helmet material="leather helmet" unbreakable="true" team-color="true">
        <enchantment level="1">projectile_protection</enchantment>
      </helmet>
      <chestplate material="leather chestplate" unbreakable="true" team-color="true">
        <enchantment level="1">projectile_protection</enchantment>
      </chestplate>
      <leggings material="chainmail leggings" unbreakable="true">
        <enchantment level="1">projectile_protection</enchantment>
      </leggings>
      <boots material="leather boots" unbreakable="true" team-color="true">
        <enchantment level="1">projectile_protection</enchantment>
      </boots>
    </kit>
  </kits>
  <spawns>
    <default yaw="90" region="observer-spawn"/>
    <spawn team="red" kit="spawn-kit" yaw="-90" region="red-spawn-point"/>
    <spawn team="blue" kit="spawn-kit" yaw="90" region="blue-spawn-point"/>
  </spawns>
  <wools>
    <wool team="blue" color="green" location="-108,12,-30" monument="green-blue-monument"/>
    <wool team="blue" color="lime" location="-108,12,30" monument="lime-blue-monument"/>
    <wool team="red" color="orange" location="108,12,30" monument="orange-red-monument"/>
    <wool team="red" color="yellow" location="108,12,-30" monument="yellow-red-monument"/>
  </wools>
  <filters>
    <team id="only-red">red</team>
    <team id="only-blue">blue</team>
    <any id="woolrooms-filter">
      <material>web</material>
      <material>stained glass</material>
      <material>stained glass pane</material>
      <material>wood</material>
      <material>stained clay</material>
      <all>
        <cause>player</cause>
        <any>
          <material>water</material>
          <material>stationary water</material>
        </any>
      </all>
    </any>
    <not id="not-red">
      <filter id="only-red"/>
    </not>
    <all id="reds-woolrooms-filter">
      <filter id="not-red"/>
      <filter id="woolrooms-filter"/>
    </all>
    <not id="not-blue">
      <filter id="only-blue"/>
    </not>
    <all id="blues-woolrooms-filter">
      <filter id="not-blue"/>
      <filter id="woolrooms-filter"/>
    </all>
    <not id="no-void">
      <void id="is-void"/>
    </not>
    <material id="only-air">air</material>
    <material id="only-iron">iron block</material>
    <all id="only-iron-cause-world">
      <material>iron block</material>
      <cause>world</cause>
    </all>
  </filters>
  <regions>
    <point id="red-spawn-point">-84,8,0</point>
    <point id="blue-spawn-point">84,8,0</point>
    <point id="observer-spawn">0,28,0</point>
    <point id="green-wool-spawn">-108,12,-30</point>
    <point id="lime-wool-spawn">-108,12,30</point>
    <point id="orange-wool-spawn">108,12,30</point>
    <point id="yellow-wool-spawn">108,12,-30</point>
    <block id="green-blue-monument">74,9,-3</block>
    <block id="lime-blue-monument">74,9,2</block>
    <block id="orange-red-monument">-75,9,2</block>
    <block id="yellow-red-monument">-75,9,-3</block>
    <rectangle id="red-spawn" min="-89,-8" max="-61,8"/>
    <rectangle id="blue-spawn" min="61,-8" max="89,8"/>
    <rectangle id="green-wool" min="-112,-36" max="-100,-24"/>
    <rectangle id="lime-wool" min="-112,24" max="-100,36"/>
    <rectangle id="orange-wool" min="100,24" max="112,36"/>
    <rectangle id="yellow-wool" min="100,-36" max="112,-24"/>
    <union id="reds-woolrooms">
      <region id="green-wool"/>
      <region id="lime-wool"/>
    </union>
    <union id="blues-woolrooms">
      <region id="orange-wool"/>
      <region id="yellow-wool"/>
    </union>
    <union id="woolrooms">
      <region id="reds-woolrooms"/>
      <region id="blues-woolrooms"/>
    </union>
    <negative id="not-build-area">
      <complement id="buildable">
        <union id="build-area">
          <rectangle id="build-area-1" min="-61,-44" max="-53,-36"/>
          <rectangle id="build-area-2" min="53,-44" max="61,-36"/>
          <rectangle id="build-area-3" min="-61,-16" max="-49,-10"/>
          <rectangle id="build-area-4" min="49,-16" max="61,-10"/>
          <rectangle id="build-area-5" min="-61,10" max="-49,16"/>
          <rectangle id="build-area-6" min="49,10" max="61,16"/>
          <rectangle id="build-area-7" min="-61,36" max="-53,44"/>
          <rectangle id="build-area-8" min="53,36" max="61,44"/>
          <rectangle id="build-area-9" min="-95,-44" max="-75,-36"/>
          <rectangle id="build-area-10" min="75,-44" max="95,-36"/>
          <rectangle id="build-area-11" min="-95,36" max="-75,44"/>
          <rectangle id="build-area-12" min="75,36" max="95,44"/>
          <rectangle id="build-area-13" min="-35,-38" max="35,38"/>
        </union>
        <rectangle id="build-hole-1" min="-35,-18" max="-23,-6"/>
        <rectangle id="build-hole-2" min="23,-18" max="35,-6"/>
        <rectangle id="build-hole-3" min="-35,6" max="-23,18"/>
        <rectangle id="build-hole-4" min="23,6" max="35,18"/>
        <rectangle id="build-hole-5" min="-9,-18" max="9,-6"/>
        <rectangle id="build-hole-6" min="-9,6" max="9,19"/>
      </complement>
    </negative>
    <complement id="spawns">
      <union id="spawn-areas">
        <region id="red-spawn"/>
        <region id="blue-spawn"/>
      </union>
      <region id="green-blue-monument"/>
      <region id="lime-blue-monument"/>
      <region id="orange-red-monument"/>
      <region id="yellow-red-monument"/>
    </complement>
    <apply enter="only-red" region="red-spawn" message="You may not enter the enemy's spawn!"/>
    <apply enter="only-blue" region="blue-spawn" message="You may not enter the enemy's spawn!"/>
    <apply enter="not-red" region="reds-woolrooms" message="You may not enter your own wool room!"/>
    <apply block="reds-woolrooms-filter" region="reds-woolrooms" message="You may not edit the wool room!"/>
    <apply enter="not-blue" region="blues-woolrooms" message="You may not enter your own wool room!"/>
    <apply block="blues-woolrooms-filter" region="blues-woolrooms" message="You may not edit the wool room!"/>
    <apply block-place="only-iron-cause-world" block-break="only-iron" region="spawns" message="You may not edit spawn!"/>
    <apply block="no-void" region="not-build-area" message="You may not edit the void!"/>
  </regions>
  <spawners>
    <spawner spawn-region="green-wool-spawn" player-region="green-wool" delay="1.5s">
      <item material="wool" damage="13"/>
    </spawner>
    <spawner spawn-region="lime-wool-spawn" player-region="lime-wool" delay="1.5s">
      <item material="wool" damage="5"/>
    </spawner>
    <spawner spawn-region="orange-wool-spawn" player-region="orange-wool" delay="1.5s">
      <item material="wool" damage="1"/>
    </spawner>
    <spawner spawn-region="yellow-wool-spawn" player-region="yellow-wool" delay="1.5s">
      <item material="wool" damage="4"/>
    </spawner>
  </spawners>
  <renewables>
    <renewable region="spawns" renew-filter="only-iron" replace-filter="only-air" avoid-players="2"/>
  </renewables>
  <block-drops>
    <rule>
      <filter>
        <any>
          <material>wood</material>
          <material>stained clay</material>
        </any>
      </filter>
      <drops>
        <item material="wood" chance="0"/>
      </drops>
    </rule>
  </block-drops>
  <itemkeep>
    <item>iron sword</item>
    <item>bow</item>
    <item>iron pickaxe</item>
    <item>iron axe</item>
    <item>iron spade</item>
    <item>shears</item>
    <item>golden apple</item>
    <item>water bucket</item>
    <item>arrow</item>
    <item>wood</item>
    <item>stained clay</item>
  </itemkeep>
  <itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>leather boots</item>
  </itemremove>
  <toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>iron spade</tool>
    <tool>shears</tool>
  </toolrepair>
  <kill-rewards>
    <kill-reward>
      <item material="wood" amount="16"/>
      <item material="stained clay" amount="8" team-color="true"/>
    </kill-reward>
  </kill-rewards>
  <hunger>
    <depletion>off</depletion>
  </hunger>
  <maxbuildheight>21</maxbuildheight>
</map>
