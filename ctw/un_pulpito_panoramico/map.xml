<map proto="1.5.1">
<name>Un Pulpito Panoramico</name>
<version>1.0.0</version>
<objective>Capture the enemy team's wool!</objective>
<created>2026-07-04</created>
<phase>staging</phase>
<include id="gapple-kill-reward"/>
<authors>
    <author uuid="4d6ecfd1-2e0e-49b6-83c6-e230efe448d4"/> <!-- 3lii3 -->
</authors>
<teams>
    <team id="red-team" color="dark red" max="6">Red</team>
    <team id="blue-team" color="blue" max="6">Blue</team>
</teams>
<kits>
    <kit id="spawn-kit">
        <clear/>
        <item slot="0" unbreakable="true" material="stone sword"/>
        <item slot="1" unbreakable="true" material="bow"/>
        <item slot="28" amount="24" material="arrow"/>
        <item slot="2" unbreakable="true" enchantment="efficiency" material="iron pickaxe"/>
        <item slot="3" unbreakable="true" enchantment="efficiency" material="iron axe"/>
        <item slot="30" unbreakable="true" material="iron spade"/>
        <item slot="4" amount="48" material="wood"/>
        <item slot="5" amount="48" material="glass"/>
        <item slot="8" material="golden apple"/>
        <helmet unbreakable="true" team-color="true" material="leather helmet"/>
        <chestplate unbreakable="true" team-color="true" material="leather chestplate"/>
        <leggings unbreakable="true" enchantment="protection projectile" material="chainmail leggings"/>
        <boots unbreakable="true" team-color="true" material="leather boots"/>
        <effect duration="3s" amplifier="255">damage resistance</effect>
    </kit>
</kits>
<spawns>
    <default>
        <region>
            <point>0.5,11,0.5</point>
        </region>
    </default>
    <spawn team="red-team" kit="spawn-kit">
        <region yaw="-90">
            <point>-46.5,9,0.5</point>
        </region>
    </spawn>
    <spawn team="blue-team" kit="spawn-kit">
        <region yaw="90">
            <point>47.5,9,0.5</point>
        </region>
    </spawn>
</spawns>
<filters>
    <all id="only-red-wr">
        <team id="only-red">red-team</team>
        <material>web</material>
    </all>
    <all id="only-blue-wr">
        <team id="only-blue">blue-team</team>
        <material>web</material>
    </all>
</filters>
<regions>
    <union id="spawns">
        <rectangle id="red-spawn" min="-43,-3" max="-50,4"/>
        <rectangle id="blue-spawn" min="44,-3" max="51,4"/>
    </union>
    <union id="wool-rooms">
        <rectangle id="red-wool-room" min="-33,-20" max="-44,-31"/> <!-- Blue capture, Red defend -->
        <rectangle id="blue-wool-room" min="34,21" max="45,32"/> <!-- Red capture, Blue defend -->
    </union>
    <union id="victory-monuments">
        <circle center="47.5,-1.5" radius="1"/>
        <circle center="-46.5,2.5" radius="1"/>
    </union>
    <negative id="void-area">
        <union id="bridgeable-area">
            <rectangle min="11,-30" max="-22,-21"/>
            <rectangle min="-10,31" max="23,22"/>
            <rectangle min="35,6" max="-34,-5"/>
            <rectangle min="-4,-21" max="5,22"/>
            <circle center="0.5,0.5" radius="18.5"/>
        </union>
    </negative>
    <apply enter="only-red" region="red-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="only-blue" region="blue-spawn" message="You may not enter the enemy team's spawn!"/>
    <apply enter="only-red" region="blue-wool-room" message="You may not enter your own wool room!"/>
    <apply enter="only-blue" region="red-wool-room" message="You may not enter your own wool room!"/>
    <apply block="only-red-wr" region="blue-wool-room" message="You may not modify the wool room!"/>
    <apply block="only-blue-wr" region="red-wool-room" message="You may not modify the wool room!"/>
    <apply enter="never" region="victory-monuments" message="You may not obstruct the victory monuments!"/>
    <apply block="never" region="spawns" message="You may not modify the spawn area!"/>
    <apply block="deny(void)" region="void-area" message="You may not modify the void area!"/>
</regions>
<wools craftable="false">
    <wool team="red-team" color="orange" location="41,10,28">
        <monument>
            <block>-47,10,2</block>
        </monument>
    </wool>
    <wool team="blue-team" color="lime" location="-40,10,-27">
        <monument>
            <block>47,10,-2</block>
        </monument>
    </wool>
</wools>
<toolrepair>
    <tool>stone sword</tool>
    <tool>bow</tool>
    <tool>arrow</tool>
    <tool>iron pickaxe</tool>
    <tool>iron axe</tool>
    <tool>iron spade</tool>
</toolrepair>
<itemremove>
    <item>leather helmet</item>
    <item>leather chestplate</item>
    <item>chainmail leggings</item>
    <item>leather boots</item>
    <item>string</item>
    <item>flint</item>
    <item>gravel</item>
    <item>dirt</item>
    <item>stained clay</item>
    <item>log 2</item>
    <item>seeds</item>
</itemremove>
<spawners>
    <spawner max-entities="3">
        <item amount="1" material="golden apple"/>
        <spawn-region>
            <block>0,11,0</block>
        </spawn-region>
        <player-region>
            <cylinder base="0.5,11,0.5" radius="2" height="3"/>
        </player-region>
    </spawner>
</spawners>
<block-drops>
    <rule>
        <filter>
            <material>wood</material>
        </filter>
        <drops>
            <item chance="0" material="wood"/>
        </drops>
    </rule>
</block-drops>
<itemkeep>
    <item>wood</item>
    <item>glass</item>
    <item>golden apple</item>
    <item>arrow</item>
</itemkeep>
<kill-rewards>
    <kill-reward>
        <item amount="16" material="wood"/>
        <item amount="16" material="glass"/>
        <item amount="8" material="arrow"/>
    </kill-reward>
</kill-rewards>
<maxbuildheight>18</maxbuildheight>
<hunger>
    <depletion>off</depletion>
</hunger>
</map>
