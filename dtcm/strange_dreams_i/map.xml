<kill-rewards>
    <kill-reward>
        <item amount="3" material="gold nugget"/>
        <item amount="12" material="arrow"/>
        <item amount="12" material="dark oak planks"/>
    </kill-reward>
    <kill-reward>
        <filter>
            <kill-streak count="5"/>
        </filter>
        <item material="tnt"/>
    </kill-reward>
</kill-rewards>
<itemkeep>
    <item>golden apple</item>
    <item>arrow</item>
</itemkeep>
<itemremove>
    <item>leather boots</item>
    <item>leather chestplate</item>
    <item>leather leggings</item>
    <item>glass</item>
    <item>dark oak planks</item>
    <item>obsidian</item>
    <item>tnt</item>
</itemremove>
<toolrepair>
    <tool>iron sword</tool>
    <tool>bow</tool>
    <tool>diamond pickaxe</tool>
    <tool>iron axe</tool>
    <tool>iron shovel</tool>
</toolrepair>
<gamerules>
    <randomTickSpeed>0</randomTickSpeed>
</gamerules>
<respawn delay="3s"/>
</map>
